            -- ══ SLIDER ══
            function GB:AddSlider(flag, opts)
                opts = opts or {}
                local mn, mx = opts.Min or 0, opts.Max or 100
                local val = math.clamp(opts.Default or mn, mn, mx)
                local sfx = opts.Suffix or ""
                self.Tab.Window.Flags[flag] = val

                local R = Instance.new("Frame"); R.Size = UDim2.new(1,0,0,36); R.BackgroundTransparency = 1; R.LayoutOrder = nxt(); R.Parent = Sec
                local L = Instance.new("TextLabel"); L.Size = UDim2.new(0.7,0,0,16); L.BackgroundTransparency = 1
                L.Text = opts.Text or flag; L.TextColor3 = C.sub; L.TextSize = 11; L.Font = Enum.Font.GothamMedium; L.TextXAlignment = Enum.TextXAlignment.Left; L.Parent = R
                local V = Instance.new("TextLabel"); V.Size = UDim2.new(0.3,0,0,16); V.Position = UDim2.new(0.7,0,0,0); V.BackgroundTransparency = 1
                V.Text = tostring(val)..sfx; V.TextColor3 = C.accent; V.TextSize = 11; V.Font = Enum.Font.GothamBold; V.TextXAlignment = Enum.TextXAlignment.Right; V.Parent = R

                local Track = Instance.new("Frame"); Track.Size = UDim2.new(1,0,0,4); Track.Position = UDim2.new(0,0,0,26)
                Track.BackgroundColor3 = C.none; Track.BorderSizePixel = 0; Track.Parent = R; corner(Track, 2)
                local Fill = Instance.new("Frame"); Fill.Size = UDim2.new(0,0,1,0); Fill.BackgroundColor3 = C.accent; Fill.BorderSizePixel = 0; Fill.Parent = Track; corner(Fill, 2)
                -- Fill gradient
                local fillGrad = Instance.new("UIGradient"); fillGrad.Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0, C.accentD),
                    ColorSequenceKeypoint.new(1, C.accentL),
                }; fillGrad.Parent = Fill

                local Thumb = Instance.new("Frame"); Thumb.Size = UDim2.new(0,10,0,10)
                Thumb.AnchorPoint = Vector2.new(0.5,0.5); Thumb.Position = UDim2.new(0,0,0.5,0)
                Thumb.BackgroundColor3 = Color3.new(1,1,1); Thumb.BorderSizePixel = 0; Thumb.Parent = Track; corner(Thumb, 99)
                -- Thumb glow
                local tGlow = Instance.new("Frame"); tGlow.Size = UDim2.new(0,18,0,18); tGlow.AnchorPoint = Vector2.new(0.5,0.5)
                tGlow.Position = UDim2.new(0.5,0,0.5,0); tGlow.BackgroundColor3 = C.accent; tGlow.BackgroundTransparency = 1
                tGlow.BorderSizePixel = 0; tGlow.ZIndex = Thumb.ZIndex - 1; tGlow.Parent = Thumb; corner(tGlow, 99)

                local function set(v, silent)
                    val = math.clamp(v, mn, mx); self.Tab.Window.Flags[flag] = val
                    local p = (val-mn)/(mx-mn)
                    V.Text = tostring(math.floor(val))..sfx
                    anim(Fill,  {Size = UDim2.new(p,0,1,0)},    0.08)
                    anim(Thumb, {Position = UDim2.new(p,0,0.5,0)}, 0.08)
                    if not silent and opts.Callback then pcall(opts.Callback, val) end
                end

                local drag = false
                R.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        drag = true
                        anim(Thumb, {Size = UDim2.new(0,12,0,12)}, 0.12)
                        anim(tGlow, {BackgroundTransparency = 0.75}, 0.15)
                    end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 and drag then
                        drag = false
                        anim(Thumb, {Size = UDim2.new(0,10,0,10)}, 0.12)
                        anim(tGlow, {BackgroundTransparency = 1}, 0.18)
                    end
                end)
                UserInputService.InputChanged:Connect(function(i)
                    if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
                        local ap = Track.AbsolutePosition; local as = Track.AbsoluteSize
                        local mp2 = UserInputService:GetMouseLocation() - GuiService:GetGuiInset()
                        local pct = math.clamp((mp2.X - ap.X) / as.X, 0, 1)
                        set(mn + pct*(mx-mn))
                    end
                end)

                set(val, true)
                local obj = {Flag = flag}
                function obj:Set(v) set(v) end; function obj:Get() return val end; return obj
            end

            -- ══ DROPDOWN ══
            function GB:AddDropdown(flag, opts)
                opts = opts or {}
                local items   = opts.Options or {}
                local isMulti = opts.Multi == true
                local MAXH    = 160

                local selected
                if isMulti then
                    selected = (type(opts.Default) == "table") and opts.Default or {}
                else
                    selected = opts.Default or items[1] or ""
                end
                self.Tab.Window.Flags[flag] = selected

                local R = Instance.new("Frame"); R.Size = UDim2.new(1,0,0,24); R.BackgroundTransparency = 1; R.LayoutOrder = nxt(); R.ClipsDescendants = false; R.Parent = Sec
                local L = Instance.new("TextLabel"); L.Size = UDim2.new(0.5,0,1,0); L.BackgroundTransparency = 1
                L.Text = opts.Text or flag; L.TextColor3 = C.sub; L.TextSize = 11; L.Font = Enum.Font.GothamMedium; L.TextXAlignment = Enum.TextXAlignment.Left; L.Parent = R

                local B = Instance.new("TextButton"); B.Size = UDim2.new(0.5,0,1,0); B.Position = UDim2.new(0.5,0,0,0)
                B.BackgroundColor3 = C.none; B.TextColor3 = C.text; B.TextSize = 10
                B.Font = Enum.Font.GothamMedium; B.AutoButtonColor = false; B.Parent = R
                corner(B, 5); pad(B, 0,0,10,6)
                stroke(B, C.line, 1, 0.4)

                local List = Instance.new("Frame"); List.Size = UDim2.new(1,0,0,0); List.Position = UDim2.new(0,0,1,2)
                List.BackgroundColor3 = C.surface; List.BorderSizePixel = 0; List.Visible = false
                List.ZIndex = 200; List.ClipsDescendants = true; List.Parent = self.Tab.Window.ScreenGui
                corner(List, 7); stroke(List, C.line, 1, 0.3)

                local SF = Instance.new("ScrollingFrame"); SF.Size = UDim2.new(1,0,1,0)
                SF.BackgroundTransparency = 1; SF.BorderSizePixel = 0; SF.ScrollBarThickness = 3
                SF.ScrollBarImageColor3 = C.accent; SF.CanvasSize = UDim2.new(0,0,0,0); SF.ZIndex = 51; SF.Parent = List
                hoverScroll(SF)

                local LL = Instance.new("UIListLayout"); LL.Padding = UDim.new(0,2); LL.SortOrder = Enum.SortOrder.LayoutOrder; LL.Parent = SF
                pad(SF, 4,4,4,4)

                local function isSel(item)
                    if isMulti then
                        for _, v in ipairs(selected) do if v == item then return true end end
                        return false
                    end
                    return selected == item
                end

                local function updateButtonText()
                    if isMulti then
                        local n = #selected
                        B.Text = n == 0 and "None ▾" or n == 1 and selected[1].." ▾" or n.." selected ▾"
                    else
                        B.Text = selected.." ▾"
                    end
                end
                updateButtonText()

                local function closeDropdown()
                    local w = B.AbsoluteSize.X
                    anim(List, {Size = UDim2.new(0,w,0,0)}, 0.15)
                    task.delay(0.15, function() List.Visible = false end)
                end

                local function refreshColors()
                    for _, ch in ipairs(SF:GetChildren()) do
                        if ch:IsA("TextButton") then
                            local sel = isSel(ch.Name)
                            ch.TextColor3 = sel and C.accent or C.sub
                            if isMulti then
                                local dot = ch:FindFirstChild("_dot")
                                if dot then dot.BackgroundColor3 = sel and C.accent or C.dim; dot.BackgroundTransparency = sel and 0 or 0.5 end
                            end
                        end
                    end
                end

                local function buildItems()
                    for _, ch in ipairs(SF:GetChildren()) do if ch:IsA("TextButton") then ch:Destroy() end end
                    for _, i in ipairs(items) do
                        local ic = i
                        local IB = Instance.new("TextButton"); IB.Name = ic
                        IB.Size = UDim2.new(1,-6,0,22); IB.BackgroundTransparency = 1
                        IB.BackgroundColor3 = C.accent; IB.Text = ic
                        IB.TextColor3 = isSel(ic) and C.accent or C.sub
                        IB.TextSize = 10; IB.Font = Enum.Font.GothamMedium
                        IB.AutoButtonColor = false; IB.ZIndex = 52; IB.Parent = SF; corner(IB, 4)

                        if isMulti then
                            local dot = Instance.new("Frame"); dot.Name = "_dot"
                            dot.Size = UDim2.new(0,7,0,7); dot.Position = UDim2.new(1,-13,0.5,-3)
                            dot.BackgroundColor3 = isSel(ic) and C.accent or C.dim
                            dot.BackgroundTransparency = isSel(ic) and 0 or 0.5
                            dot.BorderSizePixel = 0; dot.ZIndex = 53; dot.Parent = IB; corner(dot, 2)
                        end

                        IB.MouseEnter:Connect(function()  IB.BackgroundTransparency = 0.86; IB.TextColor3 = C.text end)
                        IB.MouseLeave:Connect(function()  IB.BackgroundTransparency = 1;    IB.TextColor3 = isSel(ic) and C.accent or C.sub end)
                        IB.MouseButton1Click:Connect(function()
                            if isMulti then
                                local found = false
                                for idx, v in ipairs(selected) do
                                    if v == ic then table.remove(selected, idx); found = true; break end
                                end
                                if not found then table.insert(selected, ic) end
                                self.Tab.Window.Flags[flag] = selected; refreshColors(); updateButtonText()
                                if opts.Callback then pcall(opts.Callback, selected) end
                            else
                                selected = ic; self.Tab.Window.Flags[flag] = ic
                                refreshColors(); updateButtonText(); closeDropdown()
                                if opts.Callback then pcall(opts.Callback, ic) end
                            end
                        end)
                    end
                end

                LL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    SF.CanvasSize = UDim2.new(0,0,0, LL.AbsoluteContentSize.Y+8)
                end)
                buildItems()

                B.MouseButton1Click:Connect(function()
                    if List.Visible then
                        closeDropdown()
                    else
                        local inset = GuiService:GetGuiInset()
                        local absPos = B.AbsolutePosition; local absSize = B.AbsoluteSize
                        List.Position = UDim2.new(0, absPos.X+inset.X, 0, absPos.Y+inset.Y+absSize.Y+2)
                        List.Size = UDim2.new(0, absSize.X, 0, 0); List.Visible = true
                        local contentH = LL.AbsoluteContentSize.Y+8
                        SF.CanvasSize = UDim2.new(0,0,0,contentH)
                        anim(List, {Size = UDim2.new(0, absSize.X, 0, math.min(contentH, MAXH))}, 0.22)
                    end
                end)

                local obj = {Flag = flag}
                function obj:Get() return selected end
                function obj:Set(v) selected = v; self.Tab.Window.Flags[flag] = v; updateButtonText(); refreshColors() end
                return obj
            end

            -- ══ LABEL ══
            function GB:AddLabel(text, opts)
                opts = opts or {}
                local L = Instance.new("TextLabel"); L.Size = UDim2.new(1,0,0,0)
                L.AutomaticSize = Enum.AutomaticSize.Y; L.BackgroundTransparency = 1
                L.Text = text or ""; L.TextColor3 = opts.Color or C.dim
                L.TextSize = 11; L.Font = Enum.Font.GothamMedium
                L.TextXAlignment = Enum.TextXAlignment.Left; L.TextWrapped = true
                L.LayoutOrder = nxt(); L.Parent = Sec
                local obj = {}
                function obj:Set(t)    L.Text = t end
                function obj:SetText(t) L.Text = t end
                return obj
            end

            -- ══ INPUT ══
            function GB:AddInput(flag, opts)
                opts = opts or {}
                self.Tab.Window.Flags[flag] = opts.Default or ""
                local R = Instance.new("Frame"); R.Size = UDim2.new(1,0,0,24); R.BackgroundTransparency = 1; R.LayoutOrder = nxt(); R.Parent = Sec
                local L = Instance.new("TextLabel"); L.Size = UDim2.new(0.5,0,1,0); L.BackgroundTransparency = 1
                L.Text = opts.Text or flag; L.TextColor3 = C.sub; L.TextSize = 11; L.Font = Enum.Font.GothamMedium; L.TextXAlignment = Enum.TextXAlignment.Left; L.Parent = R
                local Box = Instance.new("TextBox"); Box.Size = UDim2.new(0.5,0,1,0); Box.Position = UDim2.new(0.5,0,0,0)
                Box.BackgroundColor3 = C.none; Box.Text = opts.Default or ""; Box.PlaceholderText = opts.Placeholder or "..."
                Box.TextColor3 = C.text; Box.PlaceholderColor3 = C.dim; Box.TextSize = 10; Box.Font = Enum.Font.GothamMedium
                Box.ClipsDescendants = true; Box.TextTruncate = Enum.TextTruncate.AtEnd; Box.Parent = R
                corner(Box, 5); pad(Box, 0,0,10,10)
                local Str = stroke(Box, C.line, 1, 0.3)
                Box.Focused:Connect(function()   anim(Str, {Color = C.accent, Transparency = 0.15}, 0.15) end)
                Box.FocusLost:Connect(function()
                    anim(Str, {Color = C.line, Transparency = 0.3}, 0.18)
                    self.Tab.Window.Flags[flag] = Box.Text
                    if opts.Callback then pcall(opts.Callback, Box.Text) end
                end)
                return Box
            end

            -- ══ KEYBIND ══
            function GB:AddKeybind(flag, opts)
                opts = opts or {}
                local key = opts.Default or Enum.KeyCode.Unknown
                local binding = false
                self.Tab.Window.Flags[flag] = key
                local R = Instance.new("Frame"); R.Size = UDim2.new(1,0,0,24); R.BackgroundTransparency = 1; R.LayoutOrder = nxt(); R.Parent = Sec
                local L = Instance.new("TextLabel"); L.Size = UDim2.new(1,0,1,0); L.BackgroundTransparency = 1
                L.Text = opts.Text or flag; L.TextColor3 = C.sub; L.TextSize = 11; L.Font = Enum.Font.GothamMedium; L.TextXAlignment = Enum.TextXAlignment.Left; L.Parent = R
                local Bk = Instance.new("TextButton"); Bk.Size = UDim2.new(0,60,0,18); Bk.Position = UDim2.new(1,-60,0.5,-9)
                Bk.BackgroundColor3 = C.none; Bk.TextSize = 10; Bk.Font = Enum.Font.GothamBold; Bk.TextColor3 = C.sub; Bk.Parent = R
                corner(Bk, 4); local Str = stroke(Bk, C.line, 1, 0.3)
                local function upd()
                    local n = (key and (key.Name or tostring(key))) or "None"
                    Bk.Text = binding and "…" or (n == "Unknown" and "None" or n)
                    anim(Bk, {TextColor3 = binding and C.accent or C.sub}, 0.1)
                    anim(Str, {Color = binding and C.accent or C.line}, 0.1)
                end
                Bk.MouseButton1Click:Connect(function() binding = not binding; upd() end)
                table.insert(self.Tab.Window.Conns, UserInputService.InputBegan:Connect(function(i, gp)
                    if binding and not gp then
                        if i.KeyCode == Enum.KeyCode.Escape then binding = false; upd()
                        elseif i.UserInputType == Enum.UserInputType.Keyboard then
                            key = i.KeyCode; self.Tab.Window.Flags[flag] = key; binding = false; upd()
                            if opts.Callback then pcall(opts.Callback, key) end
                        end
                    end
                end))
                upd(); return Bk
            end

            -- ══ SEPARATOR ══
            function GB:AddSeparator()
                local S = Instance.new("Frame"); S.Size = UDim2.new(1,0,0,1)
                S.BackgroundColor3 = C.line; S.BorderSizePixel = 0; S.LayoutOrder = nxt(); S.Parent = Sec
                return S
            end

            return GB
        end
        return Tab
    end

    -- ══════════════════════════════════════
    -- SELECT TAB
    -- ══════════════════════════════════════
    function W:SelectTab(tab)
        if _sw then return end

        local prev = self.ActiveTab
        -- Quick page flash (only when actually switching tabs)
        if prev and prev ~= tab then
            anim(Fade, {BackgroundTransparency = 0.55}, 0.07, Enum.EasingStyle.Sine)
        end

        for _, t in ipairs(self.Tabs) do
            t.Page.Visible = false
            anim(t.hBtn, {TextColor3 = C.dim, BackgroundTransparency = 1}, 0.18)
            anim(t.vBtn, {TextColor3 = C.dim, BackgroundTransparency = 1}, 0.18)
            anim(t.vInd, {Size = UDim2.new(0,0,0.5,0), BackgroundTransparency = 1}, 0.18)
        end

        tab.Page.Visible = true; self.PageTitle.Text = tab.Name
        anim(tab.hBtn, {TextColor3 = C.text, BackgroundTransparency = 0.92}, 0.2)
        anim(tab.vBtn, {TextColor3 = C.text, BackgroundTransparency = 0.92}, 0.2)
        anim(tab.vInd, {Size = UDim2.new(0,2,0.5,0), BackgroundTransparency = 0}, 0.28)
        self.ActiveTab = tab

        -- Fade back in
        if prev and prev ~= tab then
            task.delay(0.07, function()
                anim(Fade, {BackgroundTransparency = 1}, 0.16, Enum.EasingStyle.Sine)
            end)
        end

        -- Slide indicator to active tab
        if not self.SidebarMode then
            local function updateInd()
                local btnAbs = tab.hBtn.AbsolutePosition; local thAbs = TH.AbsolutePosition
                local bSize  = tab.hBtn.AbsoluteSize
                if bSize.X > 0 then
                    anim(tabInd, {
                        Position = UDim2.new(0, btnAbs.X - thAbs.X, 1, -1),
                        Size     = UDim2.new(0, bSize.X, 0, 2)
                    }, 0.26, Enum.EasingStyle.Quart)
                    tabInd.BackgroundTransparency = 0
                end
            end
            if #self.Tabs <= 1 then task.defer(updateInd) else updateInd() end
        end
    end

    -- ══════════════════════════════════════
    -- CONFIG
    -- ══════════════════════════════════════
    function W:SaveConfig(name)
        if not writefile then Library:Notify({Title="Error",Message="File system not supported",Type="error"}); return end
        local d = {}
        for k, v in pairs(self.Flags) do
            local t = type(v); if t=="boolean" or t=="number" or t=="string" then d[k]=v end
        end
        local ok, err = pcall(function() writefile((name or "config")..".json", game:GetService("HttpService"):JSONEncode(d)) end)
        if ok then Library:Notify({Title="Saved",  Message=(name or "config")..".json",Type="success"})
        else       Library:Notify({Title="Error",  Message=tostring(err),              Type="error"})   end
    end

    function W:LoadConfig(name)
        if not readfile then Library:Notify({Title="Error",Message="File system not supported",Type="error"}); return end
        local ok, r = pcall(function() return game:GetService("HttpService"):JSONDecode(readfile((name or "config")..".json")) end)
        if ok and r then
            for k, v in pairs(r) do self.Flags[k] = v end
            Library:Notify({Title="Loaded", Message=(name or "config")..".json",Type="success"})
        else
            Library:Notify({Title="Error",  Message="Config not found",           Type="error"})
        end
    end

    -- ══════════════════════════════════════
    -- DESTROY
    -- ══════════════════════════════════════
    function W:Destroy()
        for _, c in ipairs(self.Conns) do pcall(function() c:Disconnect() end) end
        pcall(function() self.ScreenGui:Destroy() end)
        if getgenv then getgenv().SimpleUI = nil end
    end

    return W
end

return Library
