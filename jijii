            STDot.BackgroundColor3=C.accent; STDot.BackgroundTransparency=0.35; STDot.BorderSizePixel=0; STDot.Parent=STRow; corner(STDot,2)
            local ST = Instance.new("TextLabel"); ST.Size=UDim2.new(1,-8,1,0); ST.Position=UDim2.new(0,8,0,0)
