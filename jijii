            if side == "Center" then
                if not self.CenterCol then
                    local cc = Instance.new("Frame"); cc.Name = "Center"; cc.Size = UDim2.new(1,0,0,0)
                    cc.AutomaticSize = Enum.AutomaticSize.Y; cc.BackgroundTransparency = 1; cc.Parent = self.Cols
