            -- ══ SLIDER ══
            function GB:AddSlider(flag, opts)
                opts = opts or {}
                local mn,mx = opts.Min or 0, opts.Max or 100
                local val = math.clamp(opts.Default or mn, mn, mx)
                local sfx = opts.Suffix or ""
                self.Tab.Window.Flags[flag] = val

                local R=Instance.new("Frame"); R.Size=UDim2.new(1,0,0,S.sliderH); R.BackgroundTransparency=1; R.LayoutOrder=nxt(); R.Parent=Sec
                local L=Instance.new("TextLabel"); L.Size=UDim2.new(0.7,0,0,16); L.BackgroundTransparency=1
