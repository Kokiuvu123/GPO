-- WINDOW
-- ══════════════════════════════════════════
function Library:CreateWindow(options)
    local W = {Flags={}, Conns={}, Tabs={}, ActiveTab=nil, Minimized=false, SidebarMode=false}
    local title      = options.Title or "UI"
    local subtitle   = options.Subtitle or ""
    local defSz      = options.Size or UDim2.fromOffset(620, 440)
    local sideSz     = options.SidebarSize or UDim2.fromOffset(780, 500)
    local toggleKey  = options.ToggleKeybind or Enum.KeyCode.RightShift

    if getgenv and getgenv().SimpleUI then pcall(function() getgenv().SimpleUI:Destroy() end) end

    local SG = Instance.new("ScreenGui"); SG.Name = "SimpleUI"; SG.ResetOnSpawn = false
    SG.IgnoreGuiInset = true; SG.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    SG.DisplayOrder = 10; SG.Parent = PlayerGui
    if getgenv then getgenv().SimpleUI = SG end

    -- Main frame — starts invisible + small, fades & scales in
    local Main = Instance.new("Frame"); Main.Name = "MainFrame"
    Main.Size = UDim2.fromOffset(defSz.X.Offset * 0.92, defSz.Y.Offset * 0.92)
    Main.Position = UDim2.new(0.5,0,0.5,0); Main.AnchorPoint = Vector2.new(0.5,0.5)
    Main.BackgroundColor3 = C.bg; Main.BorderSizePixel = 0
    Main.BackgroundTransparency = 0.35; Main.ClipsDescendants = true; Main.Parent = SG
    corner(Main, 10)
    stroke(Main, C.line, 1, 0.3)

    -- Drop shadow
    local Shadow = Instance.new("ImageLabel"); Shadow.Name = "Shadow"; Shadow.BackgroundTransparency = 1
    Shadow.Position = UDim2.new(0,-18,0,-18); Shadow.Size = UDim2.new(1,36,1,36)
    Shadow.Image = "rbxassetid://5554236805"; Shadow.ImageColor3 = Color3.new(0,0,0)
    Shadow.ImageTransparency = 0.4; Shadow.ScaleType = Enum.ScaleType.Slice
    Shadow.SliceCenter = Rect.new(23,23,273,273); Shadow.ZIndex = 0; Shadow.Parent = Main

    -- Open animation: scale up + fade in
    task.spawn(function()
        task.wait()
        anim(Main, {Size = defSz, BackgroundTransparency = 0}, 0.42, Enum.EasingStyle.Quart)
    end)
    local fullSz = defSz

    -- ── Header ──────────────────────────────
    local H = Instance.new("Frame"); H.Name = "Header"; H.Size = UDim2.new(1,0,0,44)
    H.BackgroundColor3 = C.bg; H.BorderSizePixel = 0; H.ZIndex = 10; H.Parent = Main

    -- Header bottom divider
    local HL = Instance.new("Frame"); HL.Size = UDim2.new(1,-20,0,1); HL.Position = UDim2.new(0,10,1,0)
    HL.BackgroundColor3 = C.line; HL.BorderSizePixel = 0; HL.ZIndex = 10; HL.Parent = H

    -- Brand: accent dot
    local brandDot = Instance.new("Frame")
    brandDot.Size = UDim2.new(0,7,0,7); brandDot.Position = UDim2.new(0,14,0.5,-3)
    brandDot.BackgroundColor3 = C.accent; brandDot.BorderSizePixel = 0
    brandDot.ZIndex = 10; brandDot.Parent = H; corner(brandDot, 4)
    -- Glow behind dot
    local dotGlow = Instance.new("Frame")
    dotGlow.Size = UDim2.new(0,18,0,18); dotGlow.Position = UDim2.new(0.5,-9,0.5,-9)
    dotGlow.BackgroundColor3 = C.accent; dotGlow.BackgroundTransparency = 0.7
    dotGlow.BorderSizePixel = 0; dotGlow.ZIndex = brandDot.ZIndex - 1; dotGlow.Parent = brandDot
    corner(dotGlow, 99)

    -- Subtitle (small mono label above title, like frontend "ousi")
    local subLbl = Instance.new("TextLabel")
    subLbl.Size = UDim2.new(0,200,0,10); subLbl.Position = UDim2.new(0,30,0,8)
    subLbl.BackgroundTransparency = 1; subLbl.Text = subtitle ~= "" and subtitle or ""
    subLbl.TextColor3 = C.accent; subLbl.TextSize = 9
    subLbl.Font = Enum.Font.RobotoMono; subLbl.TextXAlignment = Enum.TextXAlignment.Left
    subLbl.ZIndex = 10; subLbl.Visible = subtitle ~= ""; subLbl.Parent = H

    local titleOff = subtitle ~= "" and 18 or 0
    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(0,200,0,16); titleLbl.Position = UDim2.new(0,30,0,12 + titleOff)
    titleLbl.BackgroundTransparency = 1; titleLbl.Text = title
    titleLbl.TextColor3 = C.text; titleLbl.TextSize = 14
    titleLbl.Font = Enum.Font.GothamBold; titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.ZIndex = 10; titleLbl.Parent = H

    -- Header icon buttons
    local function hBtn(sym, x)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(0,24,0,24); b.Position = UDim2.new(1,x,0.5,-12)
        b.BackgroundTransparency = 1; b.Text = sym; b.TextColor3 = C.dim
        b.TextSize = 11; b.Font = Enum.Font.GothamBold; b.ZIndex = 10; b.Parent = H
        b.MouseEnter:Connect(function()  anim(b, {TextColor3 = C.text},  0.15) end)
        b.MouseLeave:Connect(function()  anim(b, {TextColor3 = C.dim},   0.15) end)
        return b
    end
    local swBtn = hBtn("⇄", -76)

    -- macOS-style window dots
    local function windowDot(xOff, dotCol, hoverCol)
        local d = Instance.new("TextButton")
        d.Size = UDim2.new(0,11,0,11); d.Position = UDim2.new(1,xOff,0.5,-5)
        d.BackgroundColor3 = C.line; d.Text = ""; d.BorderSizePixel = 0
        d.ZIndex = 11; d.ClipsDescendants = true; d.Parent = H
        corner(d, 99)
        local s = Instance.new("UIStroke"); s.Color = dotCol; s.Thickness = 1; s.Transparency = 0.5; s.Parent = d
        d.MouseEnter:Connect(function()  anim(d, {BackgroundColor3 = hoverCol}, 0.14); anim(s, {Transparency = 0}, 0.14) end)
        d.MouseLeave:Connect(function()  anim(d, {BackgroundColor3 = C.line},   0.14); anim(s, {Transparency = 0.5}, 0.14) end)
        return d
    end

    local clsB = windowDot(-28, C.accent,                    C.accent)
    local minB = windowDot(-46, Color3.fromRGB(100,100,100), Color3.fromRGB(180,180,180))

    clsB.MouseButton1Click:Connect(function()
        anim(Main, {Size = UDim2.fromOffset(0,0), BackgroundTransparency = 0.6}, 0.32, Enum.EasingStyle.Quart)
        task.wait(0.33); Main.Visible = false; Main.Size = fullSz; Main.BackgroundTransparency = 0
    end)
    minB.MouseButton1Click:Connect(function()
        W.Minimized = not W.Minimized
        if W.Minimized then
            fullSz = Main.Size
            anim(Main, {Size = UDim2.new(fullSz.X.Scale, fullSz.X.Offset, 0, 44)}, 0.3)
        else
            anim(Main, {Size = fullSz}, 0.3)
        end
    end)
    swBtn.MouseButton1Click:Connect(function() W:SwitchMode(not W.SidebarMode) end)

    -- Drag
    local _d, _ds, _dp = false, nil, nil
    table.insert(W.Conns, H.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then _d=true; _ds=i.Position; _dp=Main.Position end
    end))
    table.insert(W.Conns, UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then _d=false end
    end))
    table.insert(W.Conns, UserInputService.InputChanged:Connect(function(i)
        if _d and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - _ds
            Main.Position = UDim2.new(_dp.X.Scale, _dp.X.Offset+d.X, _dp.Y.Scale, _dp.Y.Offset+d.Y)
        end
    end))
    table.insert(W.Conns, UserInputService.InputBegan:Connect(function(i, gp)
        if not gp and i.KeyCode == toggleKey then Main.Visible = not Main.Visible end
    end))

    -- ── Horizontal tab bar ───────────────────
    local TH = Instance.new("Frame"); TH.Name = "TabsH"
    TH.Size = UDim2.new(1,-24,0,28); TH.Position = UDim2.new(0,12,0,46)
    TH.BackgroundTransparency = 1; TH.ClipsDescendants = false; TH.Parent = Main

    local THContainer = Instance.new("Frame"); THContainer.Size = UDim2.new(1,0,1,0)
    THContainer.BackgroundTransparency = 1; THContainer.Parent = TH
    local THL = Instance.new("UIListLayout"); THL.FillDirection = Enum.FillDirection.Horizontal
    THL.Padding = UDim.new(0,6); THL.SortOrder = Enum.SortOrder.LayoutOrder; THL.Parent = THContainer

    -- Bottom divider
    local THLine = Instance.new("Frame"); THLine.Size = UDim2.new(1,0,0,1); THLine.Position = UDim2.new(0,0,1,-1)
    THLine.BackgroundColor3 = C.line; THLine.BorderSizePixel = 0; THLine.Parent = TH

    -- Sliding tab indicator (like frontend's layoutId indicator)
    local tabInd = Instance.new("Frame")
    tabInd.Size = UDim2.new(0,0,0,2); tabInd.Position = UDim2.new(0,0,1,-1)
    tabInd.BackgroundColor3 = C.accent; tabInd.BorderSizePixel = 0
    tabInd.ZIndex = 12; tabInd.Parent = TH; corner(tabInd, 1)
    -- Gradient on indicator
    local indGrad = Instance.new("UIGradient")
    indGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0,   C.accentD),
        ColorSequenceKeypoint.new(0.5, C.accent),
        ColorSequenceKeypoint.new(1,   C.accentL),
    }
    indGrad.Parent = tabInd

    -- ── Sidebar ──────────────────────────────
    local SB = Instance.new("Frame"); SB.Name = "Sidebar"
    SB.Size = UDim2.new(0,140,1,-48); SB.Position = UDim2.new(-140,0,0,44)
    SB.BackgroundColor3 = C.bg; SB.BackgroundTransparency = 1
    SB.BorderSizePixel = 0; SB.ClipsDescendants = true; SB.Parent = Main

    local SBScroll = Instance.new("ScrollingFrame"); SBScroll.Size = UDim2.new(1,0,1,0)
    SBScroll.BackgroundTransparency = 1; SBScroll.BorderSizePixel = 0; SBScroll.ScrollBarThickness = 2
    SBScroll.ScrollBarImageColor3 = C.accent; SBScroll.CanvasSize = UDim2.new(0,0,0,0)
    hoverScroll(SBScroll); SBScroll.Parent = SB
    local SBL = Instance.new("UIListLayout"); SBL.Padding = UDim.new(0,2); SBL.SortOrder = Enum.SortOrder.LayoutOrder; SBL.Parent = SBScroll
    pad(SBScroll, 6,6,10,6)
    SBL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        SBScroll.CanvasSize = UDim2.new(0,0,0, SBL.AbsoluteContentSize.Y+12)
    end)

    local SBDiv = Instance.new("Frame"); SBDiv.Size = UDim2.new(0,1,1,-16); SBDiv.Position = UDim2.new(1,-1,0,8)
    SBDiv.BackgroundColor3 = C.line; SBDiv.BackgroundTransparency = 1; SBDiv.BorderSizePixel = 0; SBDiv.Parent = SB

    -- ── Page area ────────────────────────────
    local pH = {pos = UDim2.new(0,12,0,80),  sz = UDim2.new(1,-24,1,-86)}
    local pS = {pos = UDim2.new(0,148,0,48), sz = UDim2.new(1,-156,1,-54)}

    local PageArea = Instance.new("Frame"); PageArea.Name = "PageArea"
    PageArea.Size = pH.sz; PageArea.Position = pH.pos
    PageArea.BackgroundTransparency = 1; PageArea.BorderSizePixel = 0; PageArea.ZIndex = 2; PageArea.Parent = Main

    local PageTitle = Instance.new("TextLabel")
    PageTitle.Size = UDim2.new(1,0,0,20); PageTitle.Position = UDim2.new(0,4,0,0)
    PageTitle.BackgroundTransparency = 1; PageTitle.Text = ""
    PageTitle.TextColor3 = C.sub; PageTitle.TextSize = 10
    PageTitle.Font = Enum.Font.GothamBold; PageTitle.TextXAlignment = Enum.TextXAlignment.Left
    PageTitle.ZIndex = 2; PageTitle.Parent = PageArea

    local Pages = Instance.new("Frame"); Pages.Name = "Pages"
    Pages.Size = UDim2.new(1,0,1,-24); Pages.Position = UDim2.new(0,0,0,24)
    Pages.BackgroundTransparency = 1; Pages.ZIndex = 3; Pages.Parent = PageArea

    -- Transition overlay
    local Fade = Instance.new("Frame"); Fade.Name = "Fade"; Fade.Size = UDim2.new(1,0,1,0)
    Fade.BackgroundColor3 = C.bg; Fade.BackgroundTransparency = 1
    Fade.BorderSizePixel = 0; Fade.ZIndex = 50; Fade.Parent = PageArea

    W.ScreenGui = SG; W.MainFrame = Main; W.TabsH = TH; W.Sidebar = SB; W.SBScroll = SBScroll
    W.Pages = Pages; W.PageTitle = PageTitle

    function W:Notify(o) Library:Notify(o) end

    -- ══════════════════════════════════════
    -- SWITCH MODE
    -- ══════════════════════════════════════
    local _sw = false
    function W:SwitchMode(toSB)
        if _sw or toSB == self.SidebarMode then return end
        _sw = true; self.SidebarMode = toSB

        local D    = 0.44
        local SINE  = Enum.EasingStyle.Sine
        local QUART = Enum.EasingStyle.Quart
        local OUT   = Enum.EasingDirection.Out
        local IN    = Enum.EasingDirection.In
        local INOUT = Enum.EasingDirection.InOut

        TweenService:Create(Fade, TweenInfo.new(D*0.3, SINE, INOUT), {BackgroundTransparency = 0.5}):Play()
        anim(swBtn, {TextColor3 = toSB and C.accent or C.dim}, 0.3)

        -- Hide indicator when going to sidebar
        if toSB then
            anim(tabInd, {BackgroundTransparency = 1}, 0.18)
        end

        if toSB then
            for _, t in ipairs(self.Tabs) do
                TweenService:Create(t.hBtn, TweenInfo.new(D*0.28, SINE, OUT), {TextColor3 = C.line, BackgroundTransparency = 1}):Play()
            end
            TweenService:Create(TH, TweenInfo.new(D*0.36, SINE, IN), {Position = UDim2.new(0,12,0,-50)}):Play()
        else
            TweenService:Create(SB, TweenInfo.new(D*0.4, QUART, IN), {Position = UDim2.new(-140,0,0,44)}):Play()
            TweenService:Create(SBDiv, TweenInfo.new(D*0.36, SINE, OUT), {BackgroundTransparency = 1}):Play()
        end

        task.wait(D * 0.36)
        if toSB then TH.Visible = false else SB.Visible = false end

        local target = toSB and pS or pH
        TweenService:Create(Main, TweenInfo.new(D, QUART, INOUT), {Size = toSB and sideSz or defSz}):Play()
        fullSz = toSB and sideSz or defSz
        TweenService:Create(PageArea, TweenInfo.new(D, QUART, INOUT), {Position = target.pos, Size = target.sz}):Play()

        task.wait(D * 0.44)

        if toSB then
            SB.Position = UDim2.new(-140,0,0,44); SB.Visible = true
            TweenService:Create(SB, TweenInfo.new(D*0.6, QUART, OUT), {Position = UDim2.new(0,0,0,44)}):Play()
            TweenService:Create(SBDiv, TweenInfo.new(D*0.6, QUART, OUT), {BackgroundTransparency = 0}):Play()
            for _, t in ipairs(self.Tabs) do
                t.vBtn.Position = UDim2.new(-0.2,0,0,0); t.vBtn.BackgroundTransparency = 1
                t.vBtn.TextColor3 = C.dim; t.vInd.Size = UDim2.new(0,0,0.5,0); t.vInd.BackgroundTransparency = 1
                TweenService:Create(t.vBtn, TweenInfo.new(D*0.6, QUART, OUT), {Position = UDim2.new(0,0,0,0)}):Play()
            end
        else
            TH.Position = UDim2.new(0,12,0,-50); TH.Visible = true
            for _, t in ipairs(self.Tabs) do
                t.hBtn.TextColor3 = C.dim; t.hBtn.BackgroundTransparency = 1
            end
            TweenService:Create(TH, TweenInfo.new(D*0.55, QUART, OUT), {Position = UDim2.new(0,12,0,46)}):Play()
        end

        TweenService:Create(Fade, TweenInfo.new(D*0.5, SINE, OUT), {BackgroundTransparency = 1}):Play()
        task.wait(D * 0.15)

        local a = self.ActiveTab
        if a then
            if toSB then
                TweenService:Create(a.vBtn, TweenInfo.new(0.22, SINE), {TextColor3 = C.text, BackgroundTransparency = 0.9}):Play()
                TweenService:Create(a.vInd, TweenInfo.new(0.24, QUART, OUT), {Size = UDim2.new(0,2,0.5,0), BackgroundTransparency = 0}):Play()
            else
                TweenService:Create(a.hBtn, TweenInfo.new(0.22, SINE), {TextColor3 = C.text, BackgroundTransparency = 0.9}):Play()
                -- Restore indicator
                task.defer(function()
                    local btnAbs = a.hBtn.AbsolutePosition; local thAbs = TH.AbsolutePosition
                    local bSize  = a.hBtn.AbsoluteSize
                    tabInd.BackgroundTransparency = 0
                    tabInd.Position = UDim2.new(0, btnAbs.X - thAbs.X, 1, -1)
                    tabInd.Size     = UDim2.new(0, bSize.X, 0, 2)
                end)
            end
        end

        task.wait(0.08); _sw = false
    end

