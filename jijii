local _ni = 0

function Library:Notify(opts)
    opts = opts or {}; _ni = _ni + 1
    local typeMap = {
        success = Color3.fromRGB(74, 222, 128),
        warning = Color3.fromRGB(250, 189, 47),
        error   = Color3.fromRGB(248, 113, 113),
        info    = C.accent,
    }
    local acc = typeMap[(opts.Type or "info"):lower()] or C.accent
    local dur  = opts.Duration or 3.5
    local dead = false

    -- Card
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,62); f.BackgroundColor3 = C.surface
    f.BorderSizePixel = 0; f.ClipsDescendants = true
    f.Position = UDim2.new(1,10,0,0); f.LayoutOrder = _ni; f.Parent = _nH
    corner(f, 8); stroke(f, C.line, 1, 0.4)

    -- Top gradient accent line
    local tl = accentLine(f, acc)
    tl.ZIndex = f.ZIndex + 2

    -- Left accent bar
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0,2,1,-16); bar.Position = UDim2.new(0,8,0,8)
    bar.BackgroundColor3 = acc; bar.BorderSizePixel = 0; bar.Parent = f
    corner(bar, 1)

    -- Title
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1,-28,0,18); title.Position = UDim2.new(0,18,0,10)
    title.BackgroundTransparency = 1; title.Text = opts.Title or ""
    title.TextColor3 = C.text; title.TextSize = 12
    title.Font = Enum.Font.GothamBold; title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = f

    -- Message
    local msg = Instance.new("TextLabel")
    msg.Size = UDim2.new(1,-28,0,18); msg.Position = UDim2.new(0,18,0,30)
    msg.BackgroundTransparency = 1; msg.Text = opts.Message or ""
    msg.TextColor3 = C.sub; msg.TextSize = 11; msg.TextWrapped = true
    msg.Font = Enum.Font.GothamMedium; msg.TextXAlignment = Enum.TextXAlignment.Left
    msg.Parent = f

    -- Duration progress bar (shrinks left → right)
    local prog = Instance.new("Frame")
    prog.Size = UDim2.new(1,0,0,1); prog.Position = UDim2.new(0,0,1,-1)
    prog.BackgroundColor3 = acc; prog.BackgroundTransparency = 0.5
    prog.BorderSizePixel = 0; prog.Parent = f

    local function kill()
        if dead then return end; dead = true
        anim(f, {Position = UDim2.new(1,10,0,0), BackgroundTransparency = 0.4}, 0.28, Enum.EasingStyle.Quart)
        task.wait(0.3); pcall(function() f:Destroy() end)
    end

    -- Entrance
    anim(f, {Position = UDim2.new(0,0,0,0)}, 0.32, Enum.EasingStyle.Quart)

    -- Shrink progress bar over duration
    TweenService:Create(prog, TweenInfo.new(dur, Enum.EasingStyle.Linear), {Size = UDim2.new(0,0,0,1)}):Play()

    f.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then kill() end
    end)
    task.delay(dur, kill)
end

