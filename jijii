-- ══════════════════════════════════════════
-- DESIGN TOKENS  (aligned with web frontend)
-- ══════════════════════════════════════════
local C = {
    bg      = Color3.fromRGB(8,   8,   8),    -- negro-950
    surface = Color3.fromRGB(18,  18,  18),   -- negro-900
    card    = Color3.fromRGB(26,  26,  26),   -- negro-800

    accent  = Color3.fromRGB(255, 51,  119),  -- rosa-500
    accentL = Color3.fromRGB(255, 102, 153),  -- rosa-400
    accentD = Color3.fromRGB(230, 0,   82),   -- rosa-700

    text    = Color3.fromRGB(230, 230, 235),
    sub     = Color3.fromRGB(100, 100, 106),  -- negro-400
    dim     = Color3.fromRGB(51,  51,  56),   -- negro-600

    line    = Color3.fromRGB(26,  26,  30),
    none    = Color3.fromRGB(36,  36,  40),
}

-- Quart Out ≈ frontend's power2.out — smooth without being dramatic
local function anim(inst, props, dur, style, dir)
    local t = TweenService:Create(inst,
        TweenInfo.new(dur or 0.22, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
        props)
    t:Play(); return t
end

local function corner(p, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 6); c.Parent = p
end

local function pad(p, t, b, l, r)
    local pd = Instance.new("UIPadding")
    pd.PaddingTop    = UDim.new(0, t or 0); pd.PaddingBottom = UDim.new(0, b or 0)
    pd.PaddingLeft   = UDim.new(0, l or 0); pd.PaddingRight  = UDim.new(0, r or 0)
    pd.Parent = p
end

local function stroke(p, col, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color = col or C.line; s.Thickness = thick or 1
    s.Transparency = trans or 0; s.Parent = p; return s
end

-- Horizontal gradient line (from transparent → color → transparent)
local function accentLine(parent, col)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,1); f.BackgroundColor3 = col or C.accent
    f.BorderSizePixel = 0; f.Parent = parent
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0,   Color3.new(0,0,0)),
        ColorSequenceKeypoint.new(0.2, col or C.accent),
        ColorSequenceKeypoint.new(0.8, col or C.accent),
        ColorSequenceKeypoint.new(1,   Color3.new(0,0,0)),
    }
    g.Parent = f; return f
end

local function ripple(btn, col)
    if not btn or not btn.AbsoluteSize then return end
    local mp = UserInputService:GetMouseLocation() - GuiService:GetGuiInset()
    local r  = Instance.new("Frame")
    r.Position = UDim2.new(0, mp.X - btn.AbsolutePosition.X, 0, mp.Y - btn.AbsolutePosition.Y)
    r.AnchorPoint = Vector2.new(0.5, 0.5)
    r.BackgroundColor3 = col or Color3.new(1,1,1)
    r.BackgroundTransparency = 0.55; r.BorderSizePixel = 0
    r.ZIndex = btn.ZIndex + 10; r.Parent = btn; corner(r, 99)
    local mx = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2.5
    anim(r, {Size = UDim2.new(0,mx,0,mx), BackgroundTransparency = 1}, 0.42)
    task.delay(0.45, function() pcall(function() r:Destroy() end) end)
end

local function hoverScroll(sf)
    sf.ScrollBarImageTransparency = 0.85
    sf.MouseEnter:Connect(function()  anim(sf, {ScrollBarImageTransparency = 0.1},  0.15) end)
    sf.MouseLeave:Connect(function()  anim(sf, {ScrollBarImageTransparency = 0.85}, 0.15) end)
end

