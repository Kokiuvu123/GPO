            if W.ActiveTab ~= Tab then anim(hBtn, {TextColor3 = C.text, BackgroundTransparency = 0.94}, 0.15) end
        end)
        hBtn.MouseLeave:Connect(function()
            if W.ActiveTab ~= Tab then anim(hBtn, {TextColor3 = C.dim, BackgroundTransparency = 1}, 0.15) end
        end)

