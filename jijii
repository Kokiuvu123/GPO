        end)
        vBtn.MouseLeave:Connect(function()
            if W.ActiveTab ~= Tab then
                anim(vBtn, {TextColor3 = C.dim, BackgroundTransparency = 1}, 0.15)
                anim(vInd, {Size = UDim2.new(0,0,0.5,0), BackgroundTransparency = 1}, 0.2)
