                DS.Image="rbxassetid://5554236805"; DS.ImageColor3=Color3.new(0,0,0); DS.ImageTransparency=0.82
                DS.ScaleType=Enum.ScaleType.Slice; DS.SliceCenter=Rect.new(23,23,273,273); DS.ZIndex=Dot.ZIndex-1; DS.Parent=Dot

